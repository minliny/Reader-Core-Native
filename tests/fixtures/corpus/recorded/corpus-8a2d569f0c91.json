"display: none;\">举报内容不能为空</span>\n                </div>\n            </li>\n            <li class=\"w_form_item\">\n                <span class=\"sTit\">联系方式</span>\n                <div class=\"formItem clearfix\">\n                    <div class=\"form-item mt0\">\n                        <div class=\"w-form-input\">\n                            <input type=\"text\" class=\"contact\" placeholder=\"请输入手机号或者QQ号\">\n                        </div>\n                    </div>\n                </div>\n            </li>\n            <li class=\"w_form_item js-report-guide\" style=\"display: none;\">\n                <div class=\"formItem clearfix\" style=\"line-height: 20px;\">\n                    <a href=\"/complaint_guide.html\" target=\"_blank\" class=\"link\">关于作品涉嫌抄袭的投诉指引 ></a>\n                </div>\n            </li>\n            <li class=\"w_form_item\">\n                <span class=\"sTit\">举报电话</span>\n                <div class=\"formItem clearfix\">\n                    4008559290 （周一到周五 9:00-18:00）\n                </div>\n            </li>\n        </ul>\n        <p class=\"pBtn\"><a href=\"javascript:;\" class=\"w_btn w_btn_green js-report-confirm\"\n                           style=\"width: 100px\">提交</a></p>\n    </div>\n</div>\n<!-- 举报弹窗 -->\n<script>\n    $(document).on('click', '.js-report-illegality', function () {\n        $.w_showPop($('.reject-pop'));\n        $(\"#report_cate li\").remove();\n        $.getJSON(\"/report/ajaxGetReportCategory\", function (result) {\n            if (result.status) {\n                // console.log(result.data);\n                $.each(result.data, function (index, item) {\n                    $(\"#report_cate\").append(\"<li cid=\" + item.id + \">\" + item.category_name + \"</li>\")\n                })\n            }\n        });\n    })\n\n    $(document).on('click', '#report_cate li', function () {\n        var cateId = $(this).attr('cid');\n        $('#cate_id').val(cateId);\n        if (cateId == 5) {\n   