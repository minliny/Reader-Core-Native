)\").attr(\"checked\", false).next(\"span\").css(\"color\", \"black\");\n                        }\n                        $(this).next(\"span\").css(\"color\", \"red\");\n                    } else {\n                        var $siblingsCheckedInputNum = $(this).parents(\".tag_1\").find(\"input:checked\").size();\n                        $(this).next(\"span\").css(\"color\", \"black\");\n                        if ($siblingsCheckedInputNum==0) {\n                            $firstInput.attr(\"checked\", true).next(\"span\").css(\"color\", \"red\");\n                        }\n                    }\n                })\n                $(\".tag_1 .check_radio input:checked\").next(\"span\").css(\"color\", \"red\");\n                $(\".tag_1 .check_radio input\").live(\"click\", function() {\n                    $('.check_radio').find(\"input\").next(\"span\").css('color', 'black');\n                    $(this).next(\"span\").css(\"color\", \"red\");\n                })\n\n                //��$_GET��ʼ�� bq remove_bq\n                var bq_param = decodeURIComponent(getURLParam('bq'));\n                var removebq_param = decodeURIComponent(getURLParam('removebq'));\n                //��ʼ����input��\n                $('#bq_input').val(bq_param);\n                $('#removebq_input').val(removebq_param);\n                var bq = bq_param==\"\" ? [] : bq_param.split(',');\n                var remove_bq = removebq_param==\"\" ? [] : removebq_param.split(',');\n                $(\".collectiontypes\").live(\"change\", function() {\n                    $(\".include_tags\").empty();\n                    $('#bq_input').val(\"\");\n                    bq = [];\n                    $(\".include_tags\").append('<span class=\"default_span\">����</span>');\n                    $(\"label[class$='choosed_tag']\").removeClass('choosed_tag')\n                })\n                $(\".notlikecollectiontypes\").live(\"change\", function() {\n                    $(\".without_tags\").empty();\n                    $('#removebq_input').val(\"\");\n                    remove_bq = [];\n                    $(\".without_tags\").append('<span class=\"default_span\">����</span>');\n                    //�����ѡ��ʽ\n                    $(\"label[class$='removed_tag']\").removeClass('removed_tag')\n                })\n                //���ӵ�������ǩ\n                $('.add_tags').live(\"click\", function() {\n                    //�ж��Ƿ����ӹ�\n                    var key = $(this).attr('val');\n                    if (bq.indexOf(key)!==-1) {\n                        alert('���Ѿ�������ǩ�����ӹ��˱�ǩ');\n                        return false;\n                    }\n                    if (remove_bq.indexOf(key)!==-1) {\n                        removeRemoveTag(key);\n                    }\n                    var collectiontypes = $(\"input[name='collectiontypes']:checked\").val();\n                    if (collectiontypes==\"ands\"&&((bq.length>=4&&bq.indexOf(\"148\")==-1&&key!=\"148\")||(bq.length>=5&&bq.indexOf(\"148\")!=-1))) {\n                        alert('�˲�ѯ��ʽ���ֻ��ѡ��4����ǩ����Ȩ�������⣩');\n                        return false;\n                    }\n                    $(this).parent().find('.tag_text').addClass('choosed_tag');\n                    var value = $(this).parent().attr('tagname');\n                    var html = '<span class=\"tags_span del_choosed_tag include_tag_'+key+'\" type_name=\"added\" tag_val=\"'+key+'\">'+value+'</span>';\n                    $('.include_tags > .default_span').remove();\n                    $('.include_tags').append(html);\n                    bq.push(key);\n                    $('#bq_input').val(bq.join(','));\n                })\n                $('.remove_tags').live(\"click\", function() {\n                    var key = $(this).attr('val');\n                    if (remove_bq.indexOf(key)!==-1) {\n                        alert('���Ѿ����ų���ǩ�����ӹ��˱�ǩ');\n                        return false;\n                    }\n                    if (bq.indexOf(key)!==-1) {\n                        removeIncludeTag(key);\n                    }\n                    var notlikecollectiontypes = $(\"input[name='notlikecollectiontypes']:checked\").val();\n                    if (notlikecollectiontypes==\"ands\"&&((remove_bq.length>=4&&bq.indexOf(\"148\")==-1&&key!=\"148\")||(remove_bq.length>=5&&bq.indexOf(\"148\")!=-1))) {\n                        alert('�˲�ѯ��ʽ���ֻ��ѡ��4����ǩ����Ȩ�������⣩');\n                        return false;\n                    }\n                    $(this).parent().find('.tag_text').addClass('removed_tag');\n                    var value = $(this).parent().attr('tagname');\n                    var html = '<span  class=\"tags_span del_choosed_tag remove_tag_'+key+'\" type_name=\"removed\" tag_val=\"'+key+'\">'+value+'</span>';\n                    $('.without_tags > .default_span').remove();\n                    $('.without_tags').append(html);\n                    remove_bq.push(key);\n                    $('#removebq_input').val(remove_bq.join(','));\n                })\n                $('.del_choosed_tag').live(\"click\", function() {\n                    var type_name = $(this).attr('type_name');\n                    var tag_val = $(this).attr('tag_val');\n                    if (type_name==='added') {\n                        removeIncludeTag(tag_val);\n                    } else {\n                        removeRemoveTag(tag_val);\n                    }\n                })\n                $('.tag_text').click(function() {\n                    if ($(this).hasClass('choosed_tag')) {\n                        removeIncludeTag($(this).next().attr('val'));\n                    } else if ($(this).hasClass('removed_tag')) {\n                        removeRemoveTag($(this).next().attr('val'));\n                    }\n\n                });\n\n                function removeIncludeTag(tag_val) {\n                    $(\".tag_label_\"+tag_val).removeClass('choosed_tag');\n                    for (k in bq) {\n                        if (bq[k]==tag_val) {\n                            bq.splice(k, 1);\n                        }\n                    }\n                    $('#bq_input').val(bq.join(','));\n                    $('.include_tag_' + tag_val).remove();\n                    //û�б�ǩ����ʾ����\n                    if ($(\".include_tags\").children().length==0) {\n                        $(\".include_tags\").append('<span class=\"default_span\">����</span>');\n                    }\n                }\n                function removeRemoveTag(tag_val) {\n                    $(\".tag_label_\"+tag_val).removeClass('removed_tag');\n                    for (k in remove_bq) {\n                        if (remove_bq[k]==tag_val) {\n                            remove_bq.splice(k, 1);\n                        }\n                    }\n                    $('#removebq_input').val(remove_bq.join(','));\n                    $('.remove_tag_' + tag_val).remove();\n                    //û�б�ǩ����ʾ����\n                    if ($(\".without_tags\").children().length==0) {\n                        $(\".without_tags\").append('<span class=\"default_span\">����</span>');\n                    }\n                }\n                // �����ǩƥ�䶥����ѡ��ı�ǩ tag_label_x X�� tag_val��ֵ����ȵ�\n                $(\"label[class^='tag_text tag_label_']\").live(\"click\", function() {\n                    // ����ƥ����ȡval\n                    var val = $(this).attr('class').replace(/[^0-9]/ig,\"\");\n                    $(\"span[tag_val='\"+val+\"']\").trigger('click')\n                })\n            })\n        </script>\n    </head>\n    <body>\n        <script src=\"//static.jjwxc.net/lib/function.js\"></script>\n        <link href=\"//static.jjwxc.net/css/main.css\" rel=\"stylesheet\" type=\"text/css\"/>\n        <link href=\"//static.jjwxc.net/css/channel_2010/index2010.css?ver=20260529\"\r\n      rel=\"stylesheet\"\r\n      type=\"text/css\"\r