      "response_body": "\r\n\r\n<!DOCTYPE html PUBLIC \"-//W3C//DTD XHTML 1.0 Transitional//EN\" \"//www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd\">\r\n\r\n<html xmlns=\"//www.w3.org/1999/xhtml\">\r\n<head><title>\r\n\tSF综合搜索\r\n</title><link href=\"//rs.sfacg.com/css/commonality.css\" rel=\"stylesheet\" type=\"text/css\" /><link href=\"//rs.sfacg.com/css/comic.css\" rel=\"stylesheet\" type=\"text/css\" />\r\n    <script type=\"text/javascript\" src=\"//rs.sfacg.com/JS/jquery-1.7.2.min.js\"></script>\r\n    <script type=\"text/javascript\" src=\"//rs.sfacg.com/JS/jquery.bigautocomplete.js\"></script>\r\n    <script type=\"text/javascript\" src=\"/JS/common.js\"></script>\r\n</head>\r\n<body>\r\n<table width=\"980\" border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\">\r\n  <tr>\r\n    <td width=\"300\"><img src=\"//rs.sfacg.com/images/sflogo.gif\" width=\"271\" height=\"89\" /></td>\r\n    <td align=\"right\"><table width=\"660\" height=\"70\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\r\n      <tr>\r\n        <td align=\"center\"> </td>\r\n      </tr>\r\n    </table></td>\r\n  </tr>\r\n</table>\r\n<table width=\"980\" border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\">\r\n  <tr>\r\n    <td height=\"63\" valign=\"top\" class=\"Menu_bg\"><table width=\"100%\" border=\"0\" cellspacing=\"0\" cellpadding=\"0\">\r\n      <tr class=\"F14PX white_link1\">\r\n        <td width=\"60\" height=\"40\" align=\"center\" bgcolor=\"#FFAB00\"><a href=\"//www.sfacg.com\"><b>首 页</b></a></td>\r\n        <td width=\"60\" align=\"center\"><a href=\"https://manhua.sfacg.com/\">漫 画</a></td>\r\n        <td width=\"80\" align=\"center\"><a href=\"//book.sfacg.com/\">轻小说</a></td>\r\n        <td width=\"80\" align=\"center\"><a href=\"https://passport.sfacg.com/\">我的SF</a></td>\r\n      </tr>\r\n    </table></td>\r\n  </tr>\r\n</table>\r\n<table width=\"980\" border=\"0\" align=\"center\" cellpadding=\"1\" cellspacing=\"1\" bgcolor=\"#dfdfdf\" class=\"space10px\">\r\n  <tr>\r\n    <td bgcolor=\"#FFFFFF\"><table width=\"100%\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\" bgcolor=\"#f6f6f6\">\r\n      <tr>\r\n        <td width=\"68%\" height=\"36\" style=\"padding-left: 8px;\"><script src=\"/JS/SearchBox.js\" type=\"text/javascript\"></script><div id=\"searchlist\" style=\"margin-left: 5px;float: left;\"></div>\r\n          　<a href=\"#\" class=\"Red_link1\">帮助</a></td>\r\n        <td width=\"32%\" align=\"center\">\r\n\t\t<table width=\"300\" height=\"22\" border=\"0\" cellpadding=\"0\" cellspacing=\"0\">\r\n          <tr>\r\n            <td width=\"2\" class=\"affiche_left\"></td>\r\n            <td align=\"left\" class=\"affiche_middle\"></td>\r\n            <td width=\"2\" class=\"affiche_right\"></td>\r\n          </tr>\r\n        </table>\r\n\t\t</td>\r\n      </tr>\r\n    </table></td>\r\n  </tr>\r\n</table>\r\n    <form method=\"post\" action=\"./?Key=%u6597%u7834%u82cd%u7a79&amp;S=1&amp;SS=0\" id=\"form1\">\r\n<div class=\"aspNetHidden\">\r\n<input type=\"hidden\" name=\"__VIEWSTATE\" id=\"__VIEWSTATE\" value=\"\" />\r\n</div>\r\n\r\n<div class=\"aspNetHidden\">\r\n\r\n\t<input type=\"hidden\" name=\"__VIEWSTATEGENERATOR\" id=\"__VIEWSTATEGENERATOR\" value=\"CA0B0334\" />\r\n</div>\r\n    \r\n\r\n<table width=\"980\" border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\">\r\n  <tr>\r\n    <td height=\"30\" class=\"font_gray gray_link1\">您当前的位置：<a href=\"http://www.sfacg.com\">首页</a> &gt; <a href=\"/\">SF搜索</a> &gt; <span class=\"font_red\">搜索结果</span></td>\r\n  </tr>\r\n</table>\r\n<table width=\"980\"  border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\">\r\n  <tr>\r\n    <td width=\"66%\" height=\"19\" class=\"Tab_bg\"><table width=\"84\" height=\"27\" border=\"0\" align=\"left\" cellpadding=\"0\" cellspacing=\"1\" bgcolor=\"#FFFFFF\" class=\"Tab2_frame Tab_space\" id=\"Tab_0\">\r\n      <tr>\r\n        <td align=\"center\" class=\"Tab_middle3 block_place\" id=\"Menu_0\">漫画</td>\r\n      </tr>\r\n    </table>\r\n    <table width=\"84\" height=\"27\" border=\"0\" align=\"left\" cellpadding=\"0\" cellspacing=\"1\" bgcolor=\"#CCCCCC\" class=\"Tab_space\" id=\"Tab_1\">\r\n      <tr>\r\n        <td align=\"center\" bgcolor=\"#ededed\" class=\"block_place\" id=\"Menu_1\"><a href=\"javascript:redirect('S',1);\" class=\"Tab1\">轻小说</a></td>\r\n      </tr>\r\n    </table></td>\r\n  </tr>\r\n</table>\r\n<script>initial();</script>\r\n<table width=\"980\" border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\" style=\"margin-top: 1px;\">\r\n  <tr>\r\n    <td height=\"30\" align=\"center\" bgcolor=\"#ededed\"><h1 class=\"font_red\"><b class=\"F14PX\">斗破苍穹</b><span style=\"font-size: 12px;font-weight: normal;\">(共搜索到25个结果)</span></h1></td>\r\n  </tr>\r\n</table>\r\n<table width=\"980\" border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"comic_cover Height_px22 font_gray\">\r\n<tr>\r\n<td>\r\n<script language=\"javascript\" src=\"http://comic.sfacg.com/AD/Inner/hysj2.js\"></script>\r\n</td>\r\n</tr>\r\n</table>\r\n<table width=\"980\" border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"comic_cover Height_px22 font_gray space10px\">\r\n  <tr>\r\n    <td>\r\n    \r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2019/10/068aa7df-fc2f-45b4-b6db-29738e6e6ace.jpg\" id=\"SearchResultList1___ResultList_Cover_0\" border=\"0\" alt=\"斗破苍穹之魂玉\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/249775\" id=\"SearchResultList1___ResultList_LinkInfo_0\" class=\"orange_link2\">斗破苍穹之魂玉</a></strong><br />\r\n\t  综合信息： 赤月之瞳/2024/10/23 0:45:41<br />      \r\n\t  筹谋千年一朝败亡，绝世枭雄转生为女。\n重活一世，飞升成帝、统御八荒的前尘旧梦已经一去不复返了。\n往者不可谏，来者犹可追，与故人痴缠了千年的恩怨又能否放下？\n重活一世，看似有无数选择，却也往往别无选择。</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2019/06/ec48160f-742a-4a05-af94-4b34303869d9.jpg\" id=\"SearchResultList1___ResultList_Cover_1\" border=\"0\" alt=\"斗破苍穹之冰雪绝恋\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/136931\" id=\"SearchResultList1___ResultList_LinkInfo_1\" class=\"orange_link2\">斗破苍穹之冰雪绝恋</a></strong><br />\r\n\t  综合信息： 溯源轮回/2019/7/6 21:54:27<br />      \r\n\t  更新是不可能更新的，哪怕我崩崩崩补给全保底，副本零掉落也不可能更新的！</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2020/11/2297cb03-f1d8-4b7e-90e9-14c0f1bb013c.jpg\" id=\"SearchResultList1___ResultList_Cover_2\" border=\"0\" alt=\"斗破苍穹之魂清\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/392410\" id=\"SearchResultList1___ResultList_LinkInfo_2\" class=\"orange_link2\">斗破苍穹之魂清</a></strong><br />\r\n\t  综合信息： 江韶云/2024/7/31 12:55:04<br />      \r\n\t  身祭斩帝鬼血刃之人重生为魂族圣公主\n善与恶的分界究竟在哪\n心狠手辣又该不该被万世唾弃\n冰山美人的情感寄托又该何处寻\n</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2022/02/5ec255f1-ced0-4ee1-874d-b4f9298c2474.jpg\" id=\"SearchResultList1___ResultList_Cover_3\" border=\"0\" alt=\"re斗破苍穹\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/142361\" id=\"SearchResultList1___ResultList_LinkInfo_3\" class=\"orange_link2\">re斗破苍穹</a></strong><br />\r\n\t  综合信息： 玄幻之狂龙/2023/9/18 18:27:15<br />      \r\n\t  一个月一更\n不一样的斗破，不一样的萧炎。\n昔日的废材，如今的强者。\n三十年河东，三十年河西。\n斗破苍穹，仅一人足矣！</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2020/05/f5e10c17-3df9-4414-997c-31ed4faaca3a.jpg\" id=\"SearchResultList1___ResultList_Cover_4\" border=\"0\" alt=\"斗破苍穹之火凤凰\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/330749\" id=\"SearchResultList1___ResultList_LinkInfo_4\" class=\"orange_link2\">斗破苍穹之火凤凰</a></strong><br />\r\n\t  综合信息： 笛i/2020/7/20 21:33:02<br />      \r\n\t  不得志之人必将穿越？还穿进了斗破苍穹？\n最最最重要的是，变成了女孩子！\n爱恨情仇，风雨欲来\n看与萧炎、云韵等一系列主角的冒险故事\n佛系更新哟</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2021/07/d1612376-bef7-41f0-afa3-7f0b4424205e.jpg\" id=\"SearchResultList1___ResultList_Cover_5\" border=\"0\" alt=\"斗破苍穹之倾心于你\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/469726\" id=\"SearchResultList1___ResultList_LinkInfo_5\" class=\"orange_link2\">斗破苍穹之倾心于你</a></strong><br />\r\n\t  综合信息： 乾曙螖螸/2026/4/18 22:46:47<br />      \r\n\t  熙雨：薰儿你是我的唯一，我爱你，你愿意陪我去一同见证那绚丽的世界吗？ \n薰儿：我愿意。\n\n萌新作者，更新时间不定，写的不好请见谅</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2021/12/9a8bf1ea-2009-4b88-922d-a73e37f035e2.jpg\" id=\"SearchResultList1___ResultList_Cover_6\" border=\"0\" alt=\"我用方舟角色穿越斗破苍穹\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/506403\" id=\"SearchResultList1___ResultList_LinkInfo_6\" class=\"orange_link2\">我用方舟角色穿越斗破苍穹</a></strong><br />\r\n\t  综合信息： 米哈游咩/2022/4/10 0:10:04<br />      \r\n\t  (新书意外穿越全职法师)</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2018/05/8c431f0e-035b-4262-ba0a-819f0d000acb.jpg\" id=\"SearchResultList1___ResultList_Cover_7\" border=\"0\" alt=\"斗破蒼穹之逆天改命\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/96856\" id=\"SearchResultList1___ResultList_LinkInfo_7\" class=\"orange_link2\">斗破蒼穹之逆天改命</a></strong><br />\r\n\t  综合信息： 玄宇天/2018/5/23 15:31:07<br />      \r\n\t  本文改編自《斗破蒼穹》，加入第二主角幻星離，擁有與蕭炎幾乎相同的遭遇，他們的命運會怎麼樣呢？\n「我命由我不有天！既然天命註定要我死，那我就逆天改命！天亦亡我，我滅了上天！地亦屠我，我毀了山地！我是萬古上神，荒命轉世，幻星離！」</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2021/11/bdbcafda-e7d7-463a-8933-9b560ec18dee.jpg\" id=\"SearchResultList1___ResultList_Cover_8\" border=\"0\" alt=\"琪亚娜在斗破苍穹\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/504964\" id=\"SearchResultList1___ResultList_LinkInfo_8\" class=\"orange_link2\">琪亚娜在斗破苍穹</a></strong><br />\r\n\t  综合信息： 食蜂操祈4C/2022/1/28 23:22:39<br />      \r\n\t  第二次写书，新坑。\n穿越到斗破苍穹世界变身琪亚娜，外貌琪亚娜，能力终焉，实力超强。\n剧情从三年之约开始。\n不嫁人，可百合。</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2024/11/1d665744-39fb-4045-b497-83c0b30dfcb4.jpg\" id=\"SearchResultList1___ResultList_Cover_9\" border=\"0\" alt=\"斗破苍穹：从怒怼网瘾少女开始\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/725834\" id=\"SearchResultList1___ResultList_LinkInfo_9\" class=\"orange_link2\">斗破苍穹：从怒怼网瘾少女开始</a></strong><br />\r\n\t  综合信息： 飞好71/2025/4/23 23:00:02<br />      \r\n\t  （橘味，剧情，无系统，智商在线，快节奏）\n穿越到斗气大陆，少女不服这天，也不服这地！\n人敢欺我，我干碎这人！\n天敢压我，我干碎这天！\n地敢怼我，我干碎这地！\n什么！有人敢娶我？\n我踢断他“腿”！\n什么！这人太强打不过？\n我偷偷发育，回头再一脚把他踩成屎！\n……\n多年以后，少女生下了一堆儿女！\n少女抬头望天：“我服了！”\n漂亮大姐姐捏住少女下巴：\n“真的服了吗？”</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2022/09/2e49db1a-2760-4dd4-a3a8-ce9b0c73db45.jpg\" id=\"SearchResultList1___ResultList_Cover_10\" border=\"0\" alt=\"斗破苍穹之纳兰天凤\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/591621\" id=\"SearchResultList1___ResultList_LinkInfo_10\" class=\"orange_link2\">斗破苍穹之纳兰天凤</a></strong><br />\r\n\t  综合信息： 荣耀十绝/2023/6/16 22:05:18<br />      \r\n\t  纳兰家收留了一个婴儿，只比嫣然小一岁。她将在此留下故事……</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2021/12/b9634ed8-5554-4c68-a843-7eb6129f82e3.jpg\" id=\"SearchResultList1___ResultList_Cover_11\" border=\"0\" alt=\"斗破苍穹之仙帝降临\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/509390\" id=\"SearchResultList1___ResultList_LinkInfo_11\" class=\"orange_link2\">斗破苍穹之仙帝降临</a></strong><br />\r\n\t  综合信息： 执掌诸天/2022/1/12 2:48:12<br />      \r\n\t  仙帝萧寒，曾执掌诸天万界，镇压一切，为诸天之巅。\n却因修炼走火入魔，被其手下杀害，形神俱灭。\n随后意外重生斗气大陆，这一世定重回诸天万界，斩杀一切背叛之人。</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2021/10/9f952c55-173c-4df3-82ee-beafaee117b5.jpg\" id=\"SearchResultList1___ResultList_Cover_12\" border=\"0\" alt=\"斗破苍穹之幻梦双星\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/494782\" id=\"SearchResultList1___ResultList_LinkInfo_12\" class=\"orange_link2\">斗破苍穹之幻梦双星</a></strong><br />\r\n\t  综合信息： 海侓迦娜/2024/1/18 23:14:53<br />      \r\n\t  前一本斗破的重置，两个穿越者的较量。没有其他穿越者也没有系统，单世界</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/defaultNew.jpg\" id=\"SearchResultList1___ResultList_Cover_13\" border=\"0\" alt=\"斗破苍穹之魂珏\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/685910\" id=\"SearchResultList1___ResultList_LinkInfo_13\" class=\"orange_link2\">斗破苍穹之魂珏</a></strong><br />\r\n\t  综合信息： 心塞紫荆/2024/3/20 9:33:56<br />      \r\n\t  变嫁文。变嫁文。</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2018/10/7c28170c-8e5b-4bd3-a3ab-494ced5bdb3d.jpg\" id=\"SearchResultList1___ResultList_Cover_14\" border=\"0\" alt=\"斗破苍穹之02创世复苏\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/166521\" id=\"SearchResultList1___ResultList_LinkInfo_14\" class=\"orange_link2\">斗破苍穹之02创世复苏</a></strong><br />\r\n\t  综合信息： 吾乃女王陛下/2018/10/22 16:00:24<br />      \r\n\t  我拥有了创世神的力量，代价确是失去所有感情变成02和重生在斗破苍穹世界。。</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2019/10/cef92c12-61d3-4a74-a584-cf6cc948f0f4.jpg\" id=\"SearchResultList1___ResultList_Cover_15\" border=\"0\" alt=\"斗破苍穹之轮回\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/246436\" id=\"SearchResultList1___ResultList_LinkInfo_15\" class=\"orange_link2\">斗破苍穹之轮回</a></strong><br />\r\n\t  综合信息： 帝王伪征/2020/2/12 19:01:34<br />      \r\n\t  本书已转移，搜索《斗破苍穹之重归巅峰》即可观看！</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2021/07/3b1f1184-4f62-4590-83e9-8876482818e3.jpg\" id=\"SearchResultList1___ResultList_Cover_16\" border=\"0\" alt=\"斗破苍穹之古薰儿\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/468871\" id=\"SearchResultList1___ResultList_LinkInfo_16\" class=\"orange_link2\">斗破苍穹之古薰儿</a></strong><br />\r\n\t  综合信息： 啊泰1997/2021/7/27 19:08:21<br />      \r\n\t  一代程序猿重生成为斗破苍穹小说女主角古薰儿的故事。其剧情故事可能于原著剧情有差异（原著党请绕行）</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2025/04/1488c6ef-2132-4e90-9903-057f3a6c54d7.jpg\" id=\"SearchResultList1___ResultList_Cover_17\" border=\"0\" alt=\"斗破苍穹之魂鸢儿\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/742186\" id=\"SearchResultList1___ResultList_LinkInfo_17\" class=\"orange_link2\">斗破苍穹之魂鸢儿</a></strong><br />\r\n\t  综合信息： 无敌的猫猫大人/2025/4/16 21:03:25<br />      \r\n\t  当萧炎的过往出现错误。\n本不应该存在于过去的他与没有野心游历大陆的魂天帝相识之后会发生什么。\n经历万世轮回，内心逐渐扭曲少女阴恻恻道:无论如何，无论以什么样的方式，我的爱的人或者爱我的人都必须一直陪着我。</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2022/05/774baaef-579a-43d1-9cd4-4341a4d1e042.jpg\" id=\"SearchResultList1___ResultList_Cover_18\" border=\"0\" alt=\"成为特瓦林并在斗破苍穹\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/555802\" id=\"SearchResultList1___ResultList_LinkInfo_18\" class=\"orange_link2\">成为特瓦林并在斗破苍穹</a></strong><br />\r\n\t  综合信息： 我的MA呀X4/2022/6/18 0:29:25<br />      \r\n\t  诶嘿～☆</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2018/11/bdd6cff6-0b8b-4354-abf5-35078fde5adc.jpg\" id=\"SearchResultList1___ResultList_Cover_19\" border=\"0\" alt=\"斗破苍穹之萧族斗帝\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/172699\" id=\"SearchResultList1___ResultList_LinkInfo_19\" class=\"orange_link2\">斗破苍穹之萧族斗帝</a></strong><br />\r\n\t  综合信息： 玩火的行家/2019/5/5 12:20:57<br />      \r\n\t  讲述萧族初代斗帝的故事，剧情原创，无意冒犯原作者，本人不闲，所以更新随缘，但一定完结</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/defaultNew.jpg\" id=\"SearchResultList1___ResultList_Cover_20\" border=\"0\" alt=\"斗破苍穹之魂玉Q\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/682507\" id=\"SearchResultList1___ResultList_LinkInfo_20\" class=\"orange_link2\">斗破苍穹之魂玉Q</a></strong><br />\r\n\t  综合信息： 心塞紫荆/2025/8/19 11:09:40<br />      \r\n\t  杀萧炎，抢焚决</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2022/06/1a864887-c14d-4621-b80e-0e98414611c4.jpg\" id=\"SearchResultList1___ResultList_Cover_21\" border=\"0\" alt=\"斗破苍穹之炎天异火榜\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/544385\" id=\"SearchResultList1___ResultList_LinkInfo_21\" class=\"orange_link2\">斗破苍穹之炎天异火榜</a></strong><br />\r\n\t  综合信息： 脸叔大大/2024/4/17 10:53:57<br />      \r\n\t  炎天异火榜是一部以斗破苍穹为原型的小说作品、其中还穿插了一点关于武动乾坤和大主宰的剧情。缘讲述了在炎帝萧炎破碎虚空进入三千世界后1000年后，在斗气大陆上突然出现了巨大的异变，全新异火榜炎天异火榜上面的异火们突然集体暴走危害人间，面对这种暴动，身在大千世界的萧炎十分担忧，便带领着自己的恩师药尘和众爱妻们来到自己的老家斗气大陆上，就在他们马上要出手平复暴动时，时空守望者狄兰•格兰特出现在了他们面前…</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2021/02/15b6ed07-c9a0-4566-acbf-27c5b2d975a9.jpg\" id=\"SearchResultList1___ResultList_Cover_22\" border=\"0\" alt=\"斗破苍穹之万毒噬心决\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/415178\" id=\"SearchResultList1___ResultList_LinkInfo_22\" class=\"orange_link2\">斗破苍穹之万毒噬心决</a></strong><br />\r\n\t  综合信息： 苏家沐雪/2021/3/8 21:43:28<br />      \r\n\t  阿拉德大陆的毒王路易斯在死亡后意外来到斗气大陆……</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2022/04/73f015b2-1f77-4128-afb8-dc072468872c.jpg\" id=\"SearchResultList1___ResultList_Cover_23\" border=\"0\" alt=\"斗破苍穹之开局娶夭月\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/543847\" id=\"SearchResultList1___ResultList_LinkInfo_23\" class=\"orange_link2\">斗破苍穹之开局娶夭月</a></strong><br />\r\n\t  综合信息： 暮辞MC/2022/4/27 23:07:31<br />      \r\n\t  一个有特殊爱好的女总裁一觉醒来，来到了一片陌生大陆，记忆丢失，看她如何在这片大陆上发展</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t<ul style=\"width:100%\">\r\n\t<li class=\"Conjunction\">\r\n\t<img src=\"//rs.sfacg.com/web/novel/images/NovelCover/big/2022/07/b13481bd-c0ce-4774-8261-9274be2526a6.jpg\" id=\"SearchResultList1___ResultList_Cover_24\" border=\"0\" alt=\"斗破苍穹：至尊转世\" width=\"80\" height=\"100\" /></li>\r\n\t<li><strong class=\"F14PX\"><a href=\"https://book.sfacg.com/Novel/567962\" id=\"SearchResultList1___ResultList_LinkInfo_24\" class=\"orange_link2\">斗破苍穹：至尊转世</a></strong><br />\r\n\t  综合信息： 宾美式/2022/7/22 0:36:15<br />      \r\n\t  萧忆转世重修，成为萧家第四少！</li>\r\n\t</ul>\r\n\t<hr size=\"1\" noshade=\"noshade\" />\r\n\t\r\n\t</td>\r\n  </tr>\r\n</table>\r\n<table width=\"980\" border=\"0\" align=\"center\" cellpadding=\"0\" cellspacing=\"0\">\r\n  <tr>\r\n    <td height=\"28\" valign=\"top\" bgcolor=\"#ededed\"><ul class=\"nav pagebar\" style=\"margin-right: 5px;\">\r\n      \r\n    </ul></td>\r\n  </tr>\r\n</table>\r\n    </form>\r\n    <table width=\"980\" height=\"36\"  border=\"0\" align=\"center\" cellpadding=\"8\" cellspacing=\"0\" class=\"space10px\">\r\n  <tr 