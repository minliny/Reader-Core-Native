      "response_body": "<!DOCTYPE html>\n<html lang=\"zh-CN\">\n<head>\n    <meta charset=\"UTF-8\">\n    <title>验证码 - 刺猬猫</title>\n    <link rel=\"shortcut icon\" href=\"https://www.ciweimao.com/resources/image/icon/CiWeiMao_Icon_32_R.png\">\n    <style>\n        * { box-sizing: border-box; }\n        body {\n            margin: 0;\n            min-height: 100vh;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            background: #f5f5f5;\n            font-family: \"Microsoft YaHei\", \"PingFang SC\", sans-serif;\n        }\n        .man-machine-verify-page {\n            width: 100%;\n            max-width: 420px;\n            padding: 20px;\n        }\n        .login-box {\n            width: 350px;\n            margin: 0 auto;\n            padding: 35px 40px;\n            font-size: 14px;\n            background: #fff;\n            box-shadow: 0 0 5px rgba(0, 0, 0, 0.2);\n            border-radius: 4px;\n        }\n        .form-box .code-group {\n            position: relative;\n        }\n        .form-box .code-group .form-control {\n            padding-right: 85px;\n        }\n        .form-box .code-group img {\n            width: 65px;\n            height: 28px;\n            display: block;\n            position: absolute;\n            right: 10px;\n            top: 7px;\n            cursor: pointer;\n        }\n        .form-control {\n            display: block;\n            width: 100%;\n            height: 34px;\n            padding: 6px 12px;\n            font-size: 14px;\n            line-height: 1.428571429;\n            color: #555;\n            background-color: #fff;\n            border: 1px solid #ccc;\n            border-radius: 4px;\n        }\n        .form-control:focus {\n            border-color: #fbc02d;\n            outline: 0;\n        }\n        .form-error {\n            display: none;\n            margin-top: 8px;\n            line-height: 20px;\n            color: #ff3b30;\n            font-size: 14px;\n        }\n        .form-error.show {\n            display: block;\n        }\n        #geetest-wait-login,\n        #geetest-notice-login {\n            margin: 10px 0;\n            color: #969696;\n            font-size: 14px;\n            text-align: center;\n        }\n    </style>\n</head>\n<body>\n<div class=\"man-machine-verify-page\">\n    <div class=\"login-box\">\n        <form class=\"form form-box\" name=\"J_ManMachineVerify\" id=\"J_ManMachineVerify\" data-type=\"password\">\n            <input type=\"hidden\" name=\"redirect\" id=\"redirect\" value=\"https://www.ciweimao.com/get-search-book-list/0-0-0-0-0-0/全部/斗破苍穹/1\">\n            <div class=\"form-group code-group\">\n                                        <input type=\"text\" placeholder=\"验证码\" class=\"form-control code\" id=\"code\" name=\"code\" maxlength=\"4\" autocomplete=\"off\">\n                        <img src=\"https://www.ciweimao.com/signup/verifyimg\" alt=\"请点击刷新验证码\" onclick=\"this.src='https://www.ciweimao.com/signup/verifyimg?d='+Math.random();\">\n                        <p class=\"form-error\" id=\"code-error\"></p>\n                                </div>\n        </form>\n    </div>\n</div>\n\n<script type=\"text/javascript\">\n(function () {\n    var rootPath = 'https://www.ciweimao.com/';\n    var redirectEl = document.getElementById('redirect');\n    var redirectUrl = redirectEl ? redirectEl.value : '/';\n    var source = 'get_search_book_list';\n\n    function ajax(method, url, data, onSuccess, onError) {\n        var xhr = new XMLHttpRequest();\n        var query = '';\n        if (data) {\n            var parts = [];\n            for (var key in data) {\n                if (Object.prototype.hasOwnProperty.call(data, key)) {\n                    parts.push(encodeURIComponent(key) + '=' + encodeURIComponent(data[key]));\n                }\n            }\n            query = parts.join('&');\n        }\n        if (method === 'GET' && query) {\n            url += (url.indexOf('?') > -1 ? '&' : '?') + query;\n        }\n        xhr.open(method, url, true);\n        if (method === 'POST') {\n            xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded; charset=UTF-8');\n        }\n        xhr.onreadystatechange = function () {\n            if (xhr.readyState !== 4) {\n                return;\n            }\n            if (xhr.status >= 200 && xhr.status < 300) {\n                onSuccess(xhr.responseText);\n            } else if (onError) {\n                onError();\n            }\n        };\n        xhr.send(method === 'POST' ? query : null);\n    }\n\n        var form = document.getElementById('J_ManMachineVerify');\n    var codeInput = document.getElementById('code');\n    var errorEl = document.getElementById('code-error');\n\n    function showError(msg) {\n        if (!errorEl) {\n            return;\n        }\n        errorEl.textContent = msg;\n        errorEl.classList.add('show');\n    }\n\n    function hideError() {\n        if (!errorEl) {\n            return;\n        }\n        errorEl.textContent = '';\n        errorEl.classList.remove('show');\n    }\n\n    if (form && codeInput) {\n        form.addEventListener('submit', function (e) {\n            e.preventDefault();\n            hideError();\n            var code = codeInput.value.replace(/^\\s+|\\s+$/g, '');\n            if (!code) {\n                showError('请输入验证码');\n                return;\n            }\n            ajax('GET', rootPath + 'signup/checkManVerify', { code: code, source: source }, function (result) {\n                if (result === 'true') {\n                    window.location.href = redirectUrl;\n                } else {\n                    showError('验证码不正确');\n                    var img = form.querySelector('.code-group img');\n                    if (img) {\n                        img.src = 'https://www.ciweimao.com/signup/verifyimg?d=' + Math.random();\n                    }\n                }\n            }, function () {\n                showError('网络错误，请重试');\n            });\n        });\n    }\n    })();\n</script>\n</body>\n</html>\n",
