    "searchRule": {
      "bookList": "div.result",
      "name": "a.title@text",
      "author": "span.author@text",
      "bookUrl": "a.title@href",
      "coverUrl": "img.cover@src",
      "intro": "p.intro@text",
      "kind": "span.kind@text",
      "lastChapter": "span.last@text"
    },
    "exploreRule": {
      "bookList": "li.book",
      "name": "a.title@text",
      "author": "span.author@text",
      "bookUrl": "a.title@href",
      "coverUrl": "img.cover@src",
      "intro": "p.intro@text",
      "kind": "span.kind@text",
      "lastChapter": "span.last@text",
      "exploreScreen": "[{\"title\":\"Fantasy\",\"url\":\"/explore/fantasy\",\"kind\":\"category\"},{\"title\":\"Top Rank\",\"url\":\"/rank/top\",\"kind\":\"ranking\"},{\"title\":\"Editor Channel\",\"url\":\"/channel/editor\",\"kind\":\"channel\"}]"
    },
    "bookInfoRule": {
      "name": "h1.title@text",
      "author": "span.author@text",
      "intro": "p.intro@text",
      "kind": "span.kind@text",
      "lastChapter": "a.last@text",
      "coverUrl": "img.cover@src",
      "tocUrl": "a.toc@href",
      "wordCount": "span.words@text",
      "updateTime": "time.updated@text"
    },
    "tocRule": {
      "chapterList": "ol.toc li",
      "chapterName": "a@text",
      "chapterUrl": "a@href",
      "nextTocUrl": "a.next@href"
    },
    "contentRule": {
      "title": "h1.chapter@text",
      "content": "article.content@html",
      "nextContentUrl": "a.next-content@href",
      "sourceRegex": "AD:[^<]+",
      "replaceRegex": "{{sourceId}}"
    }
  },
