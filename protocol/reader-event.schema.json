{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reader-core-native/reader-event.schema.json",
  "title": "Reader Core Event Protocol",
  "description": "JSON message protocol for Core → platform events.",
  "oneOf": [
    { "$ref": "#/$defs/ResultEvent" },
    { "$ref": "#/$defs/ErrorEvent" },
    { "$ref": "#/$defs/HostRequestEvent" }
  ],
  "$defs": {
    "ResultEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "requestId", "type", "data"],
      "properties": {
        "protocolVersion": { "type": "integer", "const": 1 },
        "requestId": {
          "type": "integer",
          "minimum": 1,
          "description": "Original positive Core command requestId that produced this result."
        },
        "type": { "type": "string", "const": "result" },
        "data": { "type": "object" }
      }
    },
    "ErrorEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "requestId", "type", "error"],
      "properties": {
        "protocolVersion": { "type": "integer", "const": 1 },
        "requestId": {
          "type": "integer",
          "description": "Original command requestId, or 0 for process-level errors emitted outside a host command."
        },
        "type": { "type": "string", "const": "error" },
        "error": { "$ref": "#/$defs/CoreError" }
      }
    },
    "HostRequestEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocolVersion", "requestId", "type", "operationId", "capability", "params"],
      "properties": {
        "protocolVersion": { "type": "integer", "const": 1 },
        "requestId": {
          "type": "integer",
          "minimum": 1,
          "description": "Original Core command requestId that is blocked on this host operation."
        },
        "type": { "type": "string", "const": "host.request" },
        "operationId": { "type": "integer", "minimum": 1 },
        "capability": {
          "type": "string",
          "pattern": "^[^\\s.]+(\\.[^\\s.]+)+$"
        },
        "params": { "type": "object" }
      }
    },
    "CoreError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "retryable"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "UNKNOWN_METHOD",
            "INVALID_PARAMS",
            "INVALID_PROTOCOL_VERSION",
            "CANCELLED",
            "INVALID_MESSAGE",
            "INTERNAL"
          ],
          "description": "Machine-readable error code."
        },
        "message": { "type": "string", "description": "Human-readable message." },
        "retryable": { "type": "boolean" },
        "details": { "type": "object" }
      }
    },
    "CoreInfoData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["abiVersion", "protocolVersion", "buildVersion", "capabilities"],
      "description": "Result data for core.info.",
      "properties": {
        "abiVersion": {
          "type": "integer",
          "minimum": 1,
          "description": "C ABI version exposed by the loaded Core runtime."
        },
        "protocolVersion": {
          "type": "integer",
          "const": 1,
          "description": "JSON protocol version implemented by this Core runtime."
        },
        "buildVersion": {
          "type": "string",
          "description": "Build/version string for diagnostics."
        },
        "capabilities": {
          "type": "array",
          "minItems": 12,
          "maxItems": 12,
          "prefixItems": [
            { "type": "string", "const": "core.info" },
            { "type": "string", "const": "runtime.ping" },
            { "type": "string", "const": "runtime.hostSmoke" },
            { "type": "string", "const": "runtime.cancel" },
            { "type": "string", "const": "runtime.status" },
            { "type": "string", "const": "runtime.shutdown" },
            { "type": "string", "const": "host.complete" },
            { "type": "string", "const": "host.error" },
            { "type": "string", "const": "host.bus.v1" },
            { "type": "string", "const": "http.execute" },
            { "type": "string", "const": "runtime.config.v1" },
            { "type": "string", "const": "remote.reading.v1" }
          ],
          "description": "Ordered V1 capability list advertised to hosts."
        }
      }
    },
    "RuntimePingData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pong", "method"],
      "description": "Result data for runtime.ping.",
      "properties": {
        "pong": {
          "type": "boolean",
          "const": true,
          "description": "Successful ping marker."
        },
        "method": {
          "type": "string",
          "const": "runtime.ping",
          "description": "Canonical method echoed by the ping result."
        }
      }
    },
    "RuntimeCancelData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cancelled"],
      "description": "Result data for runtime.cancel.",
      "properties": {
        "cancelled": {
          "type": "boolean",
          "description": "True when the target request was active and was cancelled; false when it was unknown or already completed."
        }
      }
    },
    "RuntimeStatusData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activeRequestCount",
        "activeRequestIds",
        "pendingHostOperationCount",
        "pendingHostOperations",
        "shuttingDown"
      ],
      "description": "Result data for runtime.status.",
      "properties": {
        "activeRequestCount": { "type": "integer", "minimum": 0 },
        "activeRequestIds": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        },
        "pendingHostOperationCount": { "type": "integer", "minimum": 0 },
        "pendingHostOperations": {
          "type": "array",
          "items": { "$ref": "#/$defs/PendingHostOperationStatus" }
        },
        "shuttingDown": { "type": "boolean" }
      }
    },
    "RuntimeShutdownData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["shuttingDown", "cancelledRequestIds"],
      "description": "Result data for runtime.shutdown.",
      "properties": {
        "shuttingDown": { "type": "boolean", "const": true },
        "cancelledRequestIds": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "SourceImportData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "name", "imported"],
      "description": "Result data for source.import.",
      "properties": {
        "sourceId": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Stable source identifier stored by Core."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Human-readable source name stored by Core."
        },
        "imported": {
          "type": "boolean",
          "const": true,
          "description": "Successful import marker. Failed imports are reported as error events."
        }
      }
    },
    "RemoteHttpDiagnosticsData": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "description": "Optional diagnostics attached to remote-reading results resumed from host http.execute.",
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599,
          "description": "HTTP status supplied by the host completion."
        },
        "headers": {
          "type": "object",
          "description": "HTTP headers supplied by the host completion."
        },
        "finalUrl": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Final URL observed by the host after redirect handling."
        },
        "charsetHint": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Host-observed charset hint. Core owns final decoding policy."
        },
        "session": {
          "$ref": "#/$defs/HostHttpSession",
          "description": "Opaque Core-owned session/cookie-jar handle associated with this response."
        }
      }
    },
    "HostHttpSession": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Opaque session/cookie-jar identifier owned by Core."
        }
      }
    },
    "BookSearchBookData": {
      "type": "object",
      "required": ["bookId", "title"],
      "description": "Minimal stable book object returned by book.search. Additional book metadata remains extensible.",
      "properties": {
        "bookId": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Stable book identifier from the source pipeline."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Book title from the source pipeline."
        }
      }
    },
    "BookSearchData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "books"],
      "description": "Result data for book.search.",
      "properties": {
        "sourceId": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Source identifier used by the search command."
        },
        "books": {
          "type": "array",
          "items": { "$ref": "#/$defs/BookSearchBookData" },
          "description": "Books extracted from the search response."
        },
        "http": { "$ref": "#/$defs/RemoteHttpDiagnosticsData" }
      }
    },
    "BookDetailBookData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bookId", "title", "author"],
      "description": "Stable book detail object returned by book.detail.",
      "properties": {
        "bookId": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Stable book identifier from the source pipeline."
        },
        "title": {
          "type": "string",
          "description": "Book title after detail metadata merge."
        },
        "author": {
          "type": "string",
          "description": "Book author after detail metadata merge."
        },
        "coverUrl": {
          "type": "string",
          "description": "Optional cover URL after detail metadata merge."
        },
        "intro": {
          "type": "string",
          "description": "Optional intro or summary after detail metadata merge."
        },
        "kind": {
          "type": "string",
          "description": "Optional category or kind after detail metadata merge."
        },
        "lastChapter": {
          "type": "string",
          "description": "Optional last-chapter hint after detail metadata merge."
        }
      }
    },
    "BookDetailData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "book"],
      "description": "Result data for book.detail.",
      "properties": {
        "sourceId": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Source identifier used by the detail command."
        },
        "book": { "$ref": "#/$defs/BookDetailBookData" },
        "http": { "$ref": "#/$defs/RemoteHttpDiagnosticsData" }
      }
    },
    "BookTocEntryData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "title", "url"],
      "description": "Stable table-of-contents entry returned by book.toc.",
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based chapter index within the table of contents."
        },
        "title": {
          "type": "string",
          "description": "Chapter title extracted by the source pipeline."
        },
        "url": {
          "type": "string",
          "description": "Source-relative chapter URL or path."
        }
      }
    },
    "BookTocData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "bookId", "toc"],
      "description": "Result data for book.toc.",
      "properties": {
        "sourceId": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Source identifier used by the toc command."
        },
        "bookId": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Book identifier used by the toc command."
        },
        "toc": {
          "type": "array",
          "items": { "$ref": "#/$defs/BookTocEntryData" },
          "description": "Table-of-contents entries extracted from the toc response."
        },
        "http": { "$ref": "#/$defs/RemoteHttpDiagnosticsData" }
      }
    },
    "ChapterContentData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "bookId", "chapterTitle", "content", "via"],
      "description": "Result data for chapter.content. Rule execution returns text content; JS execution returns any JSON value.",
      "properties": {
        "sourceId": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Source identifier used by the chapter command."
        },
        "bookId": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Book identifier used by the chapter command."
        },
        "chapterTitle": {
          "type": "string",
          "description": "Chapter title surfaced by the chapter command."
        },
        "content": {
          "type": ["string", "object", "array", "number", "boolean", "null"],
          "description": "Rule path returns a string; JS path returns the JSON value produced by the script."
        },
        "via": {
          "type": "string",
          "enum": ["rule", "js"],
          "description": "Execution path that produced the content."
        },
        "http": { "$ref": "#/$defs/RemoteHttpDiagnosticsData" }
      }
    },
    "ReadingProgressUpdateData": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bookId",
        "chapterIndex",
        "chapterOffset",
        "chapterProgress",
        "stored"
      ],
      "description": "Result data for reading.progress.update.",
      "properties": {
        "bookId": {
          "type": "string",
          "description": "Book identifier whose reading progress was stored."
        },
        "chapterIndex": {
          "type": "integer",
          "minimum": 0,
          "description": "Zero-based chapter index that was stored."
        },
        "chapterOffset": {
          "type": "integer",
          "minimum": 0,
          "description": "Character or byte offset stored for the current chapter."
        },
        "chapterProgress": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Fractional chapter progress stored by Core."
        },
        "stored": {
          "type": "boolean",
          "const": true,
          "description": "Successful result marker. A failed store is reported as an error event."
        }
      }
    },
    "PendingHostOperationStatus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operationId", "requestId", "capability", "state"],
      "properties": {
        "operationId": { "type": "integer", "minimum": 1 },
        "requestId": { "type": "integer", "minimum": 1 },
        "capability": {
          "type": "string",
          "pattern": "^[^\\s.]+(\\.[^\\s.]+)+$"
        },
        "state": { "type": "string", "const": "pending" }
      }
    }
  }
}
