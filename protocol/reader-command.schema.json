{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reader-core-native/reader-command.schema.json",
  "title": "Reader Core Command Protocol",
  "description": "JSON message protocol for platform → Core commands.",
  "x-reader-core-v1-capabilities": [
    "core.info",
    "runtime.ping",
    "runtime.hostSmoke",
    "host.complete",
    "host.error",
    "host.bus.v1",
    "http.execute",
    "runtime.config.v1",
    "remote.reading.v1"
  ],
  "type": "object",
  "additionalProperties": false,
  "required": ["protocolVersion", "requestId", "method"],
  "properties": {
    "protocolVersion": {
      "type": "integer",
      "const": 1,
      "description": "Protocol version. Must be 1."
    },
    "requestId": {
      "type": "integer",
      "description": "Unique request identifier for correlation."
    },
    "method": {
      "type": "string",
      "description": "Command method name, dot-separated.",
      "examples": [
        "core.info",
        "runtime.ping",
        "runtime.hostSmoke",
        "host.complete",
        "host.error",
        "source.import",
        "book.search",
        "book.detail",
        "book.toc",
        "chapter.content",
        "reading.progress.update"
      ]
    },
    "params": {
      "type": "object",
      "default": {},
      "description": "Method-specific parameters."
    }
  },
  "$defs": {
    "HostCompleteParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operationId", "result"],
      "properties": {
        "operationId": { "type": "integer" },
        "result": {
          "description": "Host capability result payload.",
          "type": "object"
        }
      }
    },
    "HostErrorParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operationId", "error"],
      "properties": {
        "operationId": { "type": "integer" },
        "error": { "$ref": "reader-event.schema.json#/$defs/CoreError" }
      }
    },
    "HostSmokeParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "capability": {
          "type": "string",
          "default": "host.smoke.echo"
        },
        "params": {
          "type": "object",
          "default": {}
        }
      }
    }
  }
}
