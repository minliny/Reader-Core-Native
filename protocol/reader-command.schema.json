            "required": ["capability"]
          },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/HostFileReadRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability": { "const": "file.write" }
            },
            "required": ["capability"]
          },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/HostFileWriteRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability": { "const": "cache.get" }
            },
            "required": ["capability"]
          },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/HostCacheGetRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability": { "const": "cache.put" }
            },
            "required": ["capability"]
          },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/HostCachePutRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability": { "const": "cookie.get" }
            },
            "required": ["capability"]
          },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/HostCookieGetRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability": { "const": "cookie.set" }
            },
            "required": ["capability"]
          },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/HostCookieSetRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability": { "const": "log.emit" }
            },
            "required": ["capability"]
          },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/HostLogEmitRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability": { "const": "time.now" }
            },
            "required": ["capability"]
          },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/HostTimeNowRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability": { "const": "system.info" }
            },
            "required": ["capability"]
          },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/HostSystemInfoRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability": { "const": "persistence.get" }
            },
            "required": ["capability"]
          },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/HostPersistenceGetRequest" }
            }
          }
        },
        {
          "if": {
            "properties": {
              "capability": { "const": "persistence.put" }
            },
            "required": ["capability"]
          },
          "then": {
            "properties": {
              "params": { "$ref": "#/$defs/HostPersistencePutRequest" }
            }
          }
        }
      ],
      "properties": {
        "capability": {
          "$ref": "#/$defs/HostCapability",
          "default": "host.smoke.echo"
        },
        "params": {
          "type": "object",
          "default": {}
        }
      }
    },
    "RuntimeCancelParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requestId"],
      "description": "Parameters for runtime.cancel. Cancels an in-flight request by its requestId.",
      "properties": {
        "requestId": {
          "type": "integer",
          "minimum": 1,
          "description": "The requestId to cancel. Must differ from the runtime.cancel command's own requestId."
        }
      }
    },
    "RuntimeStatusParams": {
      "type": "object",
      "additionalProperties": false,
      "description": "Parameters for runtime.status. Must be an empty object."
    },
    "RuntimeShutdownParams": {
      "type": "object",
      "additionalProperties": false,
      "description": "Parameters for runtime.shutdown. Must be an empty object."
    },
    "SourceImportParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "description": "Parameters for source.import. Imports one remote-reading source definition into Core runtime state.",
      "properties": {
        "sourceId": {
          "type": "string",
          "default": "",
          "description": "Stable source identifier. If omitted or blank, Core assigns one."
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Human-readable source name. Runtime validation rejects blank or whitespace-only names."
        },
        "baseUrl": {
          "type": "string",
          "default": "",
          "description": "Optional source base URL."
        },
        "rules": {
          "type": ["object", "null"],
          "default": null,
          "description": "Optional extraction rules object keyed by remote-reading stage."
        },
        "bookSource": {
          "type": ["object", "null"],
          "default": null,
          "description": "Optional raw Legado BookSource object preserved separately from V1 rules."
        }
      }
    },
    "BookSearchParams": {
