{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reader-core-native/reader-command.schema.json",
  "title": "Reader Core Command Protocol",
  "description": "JSON message protocol for platform → Core commands.",
  "x-reader-core-v1-capabilities": [
    "core.info",
    "runtime.ping",
    "runtime.hostSmoke",
    "runtime.cancel",
    "runtime.status",
    "runtime.shutdown",
    "host.complete",
    "host.error",
    "host.bus.v1",
    "http.execute",
    "runtime.config.v1",
    "remote.reading.v1"
  ],
  "x-reader-core-v1-host-capabilities": [
    "host.smoke.echo",
    "http.execute",
    "cookie.get",
    "cookie.set",
    "webview.evaluateJavaScript",
    "file.read",
    "file.write",
    "cache.get",
    "cache.put",
    "log.emit",
    "time.now",
    "system.info",
    "persistence.get",
    "persistence.put"
  ],
  "type": "object",
  "additionalProperties": false,
  "required": ["protocolVersion", "requestId", "method"],
  "properties": {
    "protocolVersion": {
      "type": "integer",
      "const": 1,
      "description": "Protocol version. Must be 1."
    },
    "requestId": {
      "type": "integer",
      "minimum": 1,
      "description": "Unique positive request identifier for correlation. Value 0 is reserved for process-level errors emitted outside a host command."
    },
    "method": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\s.]+(\\.[^\\s.]+)+$",
      "description": "Command method name, dot-separated. Must contain two or more non-empty tokens and no whitespace.",
      "examples": [
        "core.info",
        "runtime.ping",
        "runtime.hostSmoke",
        "runtime.cancel",
        "runtime.status",
        "runtime.shutdown",
        "host.complete",
        "host.error",
        "source.import",
        "book.search",
        "book.detail",
        "book.toc",
        "chapter.content",
        "reading.progress.update"
      ]
    },
    "params": {
      "type": "object",
      "default": {},
      "description": "Method-specific parameters."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "method": { "const": "core.info" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/EmptyParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "runtime.ping" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/EmptyParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "runtime.hostSmoke" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/HostSmokeParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "runtime.cancel" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/RuntimeCancelParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "runtime.status" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/RuntimeStatusParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "runtime.shutdown" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/RuntimeShutdownParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "host.complete" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/HostCompleteParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "host.error" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/HostErrorParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "source.import" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/SourceImportParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "book.search" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/BookSearchParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "book.detail" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/BookDetailParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "book.toc" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/BookTocParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "chapter.content" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/ChapterContentParams" }
        }
      }
    },
    {
      "if": {
        "properties": { "method": { "const": "reading.progress.update" } },
        "required": ["method"]
      },
      "then": {
        "properties": {
          "params": { "$ref": "#/$defs/ReadingProgressUpdateParams" }
        }
      }
    }
  ],
  "$defs": {
    "EmptyParams": {
      "type": "object",
      "additionalProperties": false,
      "description": "Parameters for no-argument control commands. Must be an empty object."
    },
    "HostCompleteParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operationId", "result"],
      "properties": {
        "operationId": { "type": "integer", "minimum": 1 },
        "result": {
          "description": "Host capability result payload. For http.execute remote-reading continuations, see #/$defs/HostHttpResponse.",
          "type": "object"
        }
      }
    },
    "HostHttpResponse": {
      "type": "object",
      "additionalProperties": true,
      "required": ["body"],
      "description": "Result payload accepted when completing a host.request with capability http.execute.",
      "properties": {
        "body": {
          "type": "string",
          "description": "HTTP response body consumed by Core remote-reading rules."
        },
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599,
          "description": "Optional HTTP status code accepted by Core for diagnostics."
        },
        "headers": {
          "type": ["object", "null"],
          "default": {},
          "description": "Optional HTTP response headers accepted by Core for diagnostics."
        },
        "finalUrl": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Final URL observed by the host after redirect handling. Diagnostic in V1."
        },
        "charsetHint": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Optional host-observed charset hint. Core owns final decoding policy."
        },
        "bodyBase64": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Optional raw response body bytes encoded as Base64. V1 still requires body for compatibility."
        },
        "session": {
          "$ref": "#/$defs/HostHttpSession",
          "description": "Opaque Core-owned session/cookie-jar handle associated with the response."
        },
        "redirects": {
          "type": "array",
          "items": { "$ref": "#/$defs/HostHttpRedirect" },
          "description": "Redirect hops observed by the host HTTP stack."
        },
        "cookies": {
          "type": "array",
          "items": { "$ref": "#/$defs/HostHttpCookie" },
          "description": "Cookie metadata observed or applied by the host HTTP stack."
        }
      }
    },
    "HostHttpRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "description": "Host HTTP request descriptor emitted for remote-reading commands.",
      "properties": {
        "url": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Absolute or host-resolvable URL to fetch. Must not be empty or whitespace-only."
        },
        "method": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "default": "GET",
          "description": "HTTP method. Defaults to GET and must not be empty or whitespace-only."
        },
        "headers": {
          "type": "object",
          "default": {},
          "description": "HTTP request headers."
        },
        "body": {
          "type": ["string", "null"],
          "default": null,
          "description": "Optional request body."
        },
        "charset": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Optional response charset expectation or hint supplied by Core."
        },
        "followRedirects": {
          "type": "boolean",
          "description": "Whether the host may follow redirects for this request. Defaults are host-contract defined; hosts must not infer platform defaults."
        },
        "maxRedirects": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum redirect hops the host may follow when followRedirects is true."
        },
        "retry": {
          "$ref": "#/$defs/HostHttpRetryPolicy",
          "description": "Core-owned retry policy executed by the host transport."
        },
        "usePlatformCookieJar": {
          "type": "boolean",
          "description": "Whether the host may use its platform cookie jar. False keeps cookie state Core-owned."
        },
        "session": {
          "$ref": "#/$defs/HostHttpSession",
          "description": "Opaque Core-owned session/cookie-jar handle for this request."
        }
      }
    },
    "HostHttpRetryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["maxAttempts"],
      "properties": {
        "maxAttempts": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of transport attempts including the first attempt."
        },
        "backoffMillis": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional base retry backoff in milliseconds."
        }
      }
    },
    "HostHttpSession": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Opaque session/cookie-jar identifier owned by Core."
        }
      }
    },
    "HostHttpRedirect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "fromUrl", "toUrl"],
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 300,
          "maximum": 399
        },
        "fromUrl": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "toUrl": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "headers": {
          "type": "object",
          "description": "Optional redirect response headers."
        }
      }
    },
    "HostHttpCookie": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "value": { "type": "string" },
        "domain": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "expiresAt": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        },
        "httpOnly": { "type": "boolean" },
        "secure": { "type": "boolean" },
        "sameSite": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        }
      }
    },
    "HostCapability": {
      "type": "string",
      "enum": [
        "host.smoke.echo",
        "http.execute",
        "cookie.get",
        "cookie.set",
        "webview.evaluateJavaScript",
        "file.read",
        "file.write",
        "cache.get",
        "cache.put",
        "log.emit",
        "time.now",
        "system.info",
        "persistence.get",
        "persistence.put"
      ],
      "description": "Closed set of host-owned capabilities Core may request."
    },
    "HostErrorParams": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operationId", "error"],
      "properties": {
        "operationId": { "type": "integer", "minimum": 1 },
        "error": { "$ref": "reader-event.schema.json#/$defs/CoreError" },
        "diagnostics": {
          "$ref": "#/$defs/HostErrorDiagnostics",
          "description": "Optional host-owned execution diagnostics. Core adds operation correlation before surfacing the error."
        }
      }
    },
    "HostErrorDiagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "phase"],
      "description": "Typed diagnostics for a failed host capability execution. Platforms report capability facts only and must not interpret Legado rules.",
      "properties": {
        "code": { "$ref": "#/$defs/HostErrorCode" },
        "phase": { "$ref": "#/$defs/HostErrorPhase" },
        "message": {
          "type": "string",
          "description": "Optional host-side diagnostic message."
        },
        "details": {
          "type": "object",
          "default": {},
          "description": "Optional structured host-owned diagnostic facts."
        }
      }
    },
    "HostErrorCode": {
      "type": "string",
      "enum": [
        "CAPABILITY_UNAVAILABLE",
        "PERMISSION_DENIED",
        "TIMEOUT",
        "NETWORK_ERROR",
        "TLS_ERROR",
        "HTTP_ERROR",
        "INVALID_RESPONSE",
        "CANCELLED",
        "INTERNAL"
      ]
    },
    "HostErrorPhase": {
      "type": "string",
      "enum": ["request", "transport", "response", "decode", "storage", "runtime"]
    },
    "HostWebViewEvaluateJavaScriptRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document", "javaScript"],
      "description": "Request params for webview.evaluateJavaScript. Core supplies document input and JavaScript; the host only evaluates the script in a platform WebView.",
      "properties": {
        "document": { "$ref": "#/$defs/HostWebViewDocument" },
        "javaScript": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "JavaScript source supplied by Core."
        },
        "timeoutMillis": {
          "type": "integer",
          "minimum": 1,
          "description": "Optional execution timeout requested by Core."
        },
        "profileId": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Optional opaque WebView profile/session handle."
        }
      }
    },
    "HostWebViewEvaluateJavaScriptResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "description": "Result payload accepted when completing a host.request with capability webview.evaluateJavaScript.",
      "properties": {
        "value": {
          "description": "Raw JSON value returned by host JavaScript evaluation.",
          "type": ["string", "object", "array", "number", "boolean", "null"]
        },
        "finalUrl": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Optional final WebView URL after loading."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S",
          "description": "Optional document title observed by the host."
        }
      }
    },
    "HostWebViewDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "oneOf": [
        {
          "required": ["body"],
          "properties": {
            "kind": { "const": "html" },
            "body": { "type": "string", "minLength": 1, "pattern": "\\S" },
            "baseUrl": { "type": "string", "minLength": 1, "pattern": "\\S" }
          },
          "not": { "required": ["url"] }
        },
        {
          "required": ["url"],
          "properties": {
            "kind": { "const": "url" },
            "url": { "type": "string", "minLength": 1, "pattern": "\\S" }
          },
          "not": {
            "anyOf": [
              { "required": ["body"] },
              { "required": ["baseUrl"] }
            ]
          }
        }
      ],
      "properties": {
        "kind": { "type": "string", "enum": ["html", "url"] },
        "body": { "type": "string" },
        "url": { "type": "string" },
        "baseUrl": { "type": "string" }
      }
    },
    "HostFileReadRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "description": "Request params for file.read. Core supplies an opaque path and byte bounds; hosts only read bytes/content.",
      "properties": {
        "path": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "encoding": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "byteOffset": { "type": "integer", "minimum": 0 },
        "maxBytes": { "type": "integer", "minimum": 1 }
      }
    },
    "HostFileReadResponse": {
      "type": "object",
      "additionalProperties": false,
      "oneOf": [
        { "required": ["content"], "not": { "required": ["contentBase64"] } },
        { "required": ["contentBase64"], "not": { "required": ["content"] } }
      ],
      "description": "Result payload accepted when completing a host.request with capability file.read.",
      "properties": {
        "content": { "type": "string" },
        "contentBase64": { "type": "string" },
        "encoding": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "byteLength": { "type": "integer", "minimum": 0 }
      }
    },
    "HostFileWriteRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "oneOf": [
        { "required": ["content"], "not": { "required": ["contentBase64"] } },
        { "required": ["contentBase64"], "not": { "required": ["content"] } }
      ],
      "description": "Request params for file.write. Core supplies the destination path and bytes/content.",
      "properties": {
        "path": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "content": { "type": "string" },
        "contentBase64": { "type": "string" },
        "encoding": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "createDirectories": { "type": "boolean" },
        "append": { "type": "boolean" }
      }
    },
    "HostFileWriteResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["written"],
      "description": "Result payload accepted when completing a host.request with capability file.write.",
      "properties": {
        "written": { "type": "boolean", "const": true },
        "byteLength": { "type": "integer", "minimum": 0 }
      }
    },
    "HostCacheGetRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "key"],
      "description": "Request params for cache.get. Namespace and key are Core-owned opaque identifiers.",
      "properties": {
        "namespace": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "key": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostCacheGetResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hit"],
      "allOf": [
        {
          "if": {
            "properties": { "hit": { "const": true } },
            "required": ["hit"]
          },
          "then": {
            "oneOf": [
              { "required": ["value"], "not": { "required": ["valueBase64"] } },
              { "required": ["valueBase64"], "not": { "required": ["value"] } }
            ]
          },
          "else": {
            "not": {
              "anyOf": [
                { "required": ["value"] },
                { "required": ["valueBase64"] }
              ]
            }
          }
        }
      ],
      "description": "Result payload accepted when completing a host.request with capability cache.get.",
      "properties": {
        "hit": { "type": "boolean" },
        "value": { "type": "string" },
        "valueBase64": { "type": "string" },
        "expiresAt": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostCachePutRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "key"],
      "oneOf": [
        { "required": ["value"], "not": { "required": ["valueBase64"] } },
        { "required": ["valueBase64"], "not": { "required": ["value"] } }
      ],
      "description": "Request params for cache.put. Core supplies opaque namespace/key and bytes/content to store.",
      "properties": {
        "namespace": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "key": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "value": { "type": "string" },
        "valueBase64": { "type": "string" },
        "ttlMillis": { "type": "integer", "minimum": 1 }
      }
    },
    "HostCachePutResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stored"],
      "description": "Result payload accepted when completing a host.request with capability cache.put.",
      "properties": {
        "stored": { "type": "boolean", "const": true },
        "expiresAt": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostCookieRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "value": { "type": "string" },
        "domain": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "path": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "expiresAt": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "httpOnly": { "type": "boolean" },
        "secure": { "type": "boolean" },
        "sameSite": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostCookieGetRequest": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        { "required": ["url"] },
        { "required": ["domain"] },
        { "required": ["sessionId"] }
      ],
      "description": "Request params for cookie.get. Core supplies lookup scope; host only returns cookie records.",
      "properties": {
        "url": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "domain": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "name": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "sessionId": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostCookieGetResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cookies"],
      "description": "Result payload accepted when completing a host.request with capability cookie.get.",
      "properties": {
        "cookies": {
          "type": "array",
          "items": { "$ref": "#/$defs/HostCookieRecord" }
        }
      }
    },
    "HostCookieSetRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cookie"],
      "description": "Request params for cookie.set. Core supplies a cookie record; host only stores it for the scoped jar.",
      "properties": {
        "cookie": { "$ref": "#/$defs/HostCookieRecord" },
        "url": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "sessionId": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostCookieSetResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stored"],
      "description": "Result payload accepted when completing a host.request with capability cookie.set.",
      "properties": {
        "stored": { "type": "boolean", "const": true }
      }
    },
    "HostLogLevel": {
      "type": "string",
      "enum": ["trace", "debug", "info", "warn", "error"]
    },
    "HostLogEmitRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "message"],
      "description": "Request params for log.emit. Core supplies structured log facts; host only emits them.",
      "properties": {
        "level": { "$ref": "#/$defs/HostLogLevel" },
        "message": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "target": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "fields": { "type": "object", "default": {} }
      }
    },
    "HostLogEmitResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["emitted"],
      "description": "Result payload accepted when completing a host.request with capability log.emit.",
      "properties": {
        "emitted": { "type": "boolean", "const": true }
      }
    },
    "HostTimeNowRequest": {
      "type": "object",
      "additionalProperties": false,
      "description": "Request params for time.now. Core may request an optional clock/timezone fact.",
      "properties": {
        "clock": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "timezone": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostTimeNowResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unixMillis", "iso8601"],
      "description": "Result payload accepted when completing a host.request with capability time.now.",
      "properties": {
        "unixMillis": { "type": "integer", "minimum": 0 },
        "iso8601": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "timezone": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostSystemInfoRequest": {
      "type": "object",
      "additionalProperties": false,
      "description": "Request params for system.info. Keys are Core-owned opaque fact names.",
      "properties": {
        "keys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "pattern": "\\S" },
          "default": []
        }
      }
    },
    "HostSystemInfoResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["info"],
      "description": "Result payload accepted when completing a host.request with capability system.info.",
      "properties": {
        "info": { "type": "object" }
      }
    },
    "HostPersistenceGetRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "key"],
      "description": "Request params for persistence.get. Namespace/key are Core-owned opaque identifiers.",
      "properties": {
        "namespace": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "key": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostPersistenceGetResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["found"],
      "allOf": [
        {
          "if": {
            "properties": { "found": { "const": true } },
            "required": ["found"]
          },
          "then": {
            "oneOf": [
              { "required": ["value"], "not": { "required": ["valueBase64"] } },
              { "required": ["valueBase64"], "not": { "required": ["value"] } }
            ]
          },
          "else": {
            "not": {
              "anyOf": [
                { "required": ["value"] },
                { "required": ["valueBase64"] }
              ]
            }
          }
        }
      ],
      "description": "Result payload accepted when completing a host.request with capability persistence.get.",
      "properties": {
        "found": { "type": "boolean" },
        "value": { "type": "string" },
        "valueBase64": { "type": "string" },
        "revision": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostPersistencePutRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["namespace", "key"],
      "oneOf": [
        { "required": ["value"], "not": { "required": ["valueBase64"] } },
        { "required": ["valueBase64"], "not": { "required": ["value"] } }
      ],
      "description": "Request params for persistence.put. Core supplies opaque namespace/key and bytes/content to store.",
      "properties": {
        "namespace": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "key": { "type": "string", "minLength": 1, "pattern": "\\S" },
        "value": { "type": "string" },
        "valueBase64": { "type": "string" },
        "expectedRevision": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostPersistencePutResponse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stored"],
      "description": "Result payload accepted when completing a host.request with capability persistence.put.",
      "properties": {
        "stored": { "type": "boolean", "const": true },
        "revision": { "type": "string", "minLength": 1, "pattern": "\\S" }
      }
    },
    "HostSmokeParams": {
      "type": "object",
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "capability": { "const": "webview.evaluateJavaScript" }
