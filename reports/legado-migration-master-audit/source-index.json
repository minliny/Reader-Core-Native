  "project_definition": {
    "primary_goal": "把现有 Reader 项目迁移为以 Rust Reader-Core 为唯一业务内核、由 iOS、Android、HarmonyOS 三端共用的统一架构。",
    "source_of_truth_order": [
      "本地仓库是唯一事实来源。",
      "Reader-Core 定义旧业务能力、迁移资产和期望行为证据。",
      "Reader for iOS、Reader for Android、Reader for HarmonyOS 定义真实宿主接入方式。",
      "目标 Rust 仓库统一使用 Reader-Core-Native。",
      "构建、测试和三端可运行结果证明迁移完成。"
    ],
    "guardrails": [
      "开始前必须扫描本地仓库并检查 status、branch、log。",
      "不得优先依赖远程 GitHub 或历史讨论覆盖本地代码。",
      "不得修改 dirty 仓库中的非任务拥有文件。",
      "平台 wrapper 不定义业务语义，业务语义必须回到 Rust Core。",
      "不得把 wrapper smoke 或静态报告声明为 App/device 完成。"
    ]
  },
