{
  "source": {
    "bookSourceName": "Sanitized HTML Trio Source",
    "bookSourceUrl": "https://books.example.test",
    "bookSourceType": 0,
    "bookSourceGroup": "sanitized-corpus",
    "enabled": true,
    "searchUrl": "https://books.example.test/search?q={{key}}&page={{page}}",
    "ruleSearch": {
      "bookList": "css:#results li.item",
      "name": "css:li.item@text##|.*",
      "author": "",
      "bookUrl": "css:li.item@text##.*\\|"
    },
    "ruleToc": {
      "chapterList": "css:#chapters li.chapter",
      "chapterName": "css:li.chapter@text##|.*",
      "chapterUrl": "css:li.chapter@text##.*\\|"
    },
    "ruleContent": {
      "content": "css:.content@text"
    }
  },
  "samples": {
