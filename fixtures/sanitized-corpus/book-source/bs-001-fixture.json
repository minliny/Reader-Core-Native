{
  "source": {
    "bookSourceName": "Sanitized Demo Source",
    "bookSourceUrl": "https://books.example.test",
    "bookSourceType": 0,
    "bookSourceGroup": "sanitized-corpus",
    "enabled": true,
    "searchUrl": "https://books.example.test/search?q={{key}}&page={{page}}",
    "ruleSearch": {
      "bookList": "$.books[*]",
      "name": "$.title",
      "author": "$.author",
      "intro": "$.intro",
      "coverUrl": "$.cover",
      "bookUrl": "$.url"
    },
    "ruleBookInfo": {
      "name": "$.detail.title",
      "author": "$.detail.author",
      "intro": "$.detail.intro",
      "coverUrl": "$.detail.cover",
      "tocUrl": "$.detail.tocUrl"
    },
    "ruleToc": {
      "chapterList": "$.toc[*]",
      "chapterName": "$.title",
      "chapterUrl": "$.url"
    },
    "ruleContent": {
      "content": "p@text"
    }
  },
  "samples": {
    "searchResponse": {
      "books": [
        {
          "title": "Sample Volume One",
          "author": "Author Alpha",
          "intro": "A short sanitized intro.",
          "cover": "https://img.example.test/c1.png",
          "url": "https://books.example.test/b/1"
        },
        {
          "title": "Placeholder Tale",
          "author": "Author Beta",
          "intro": "Another sanitized intro.",
          "cover": "https://img.example.test/c2.png",
          "url": "https://books.example.test/b/2"
        }
      ]
    },
    "detailResponse": {
      "detail": {
        "title": "Sample Volume One",
        "author": "Author Alpha",
        "intro": "A short sanitized intro for the detail page.",
        "cover": "https://img.example.test/c1.png",
        "tocUrl": "https://books.example.test/b/1/toc"
      }
    },
    "tocResponse": {
      "toc": [
        { "title": "Chapter 1", "url": "https://books.example.test/b/1/c1" },
        { "title": "Chapter 2", "url": "https://books.example.test/b/1/c2" }
      ]
    },
    "chapterResponse": "<html><body><p>First sanitized paragraph.</p><p>Second sanitized paragraph.</p></body></html>"
  }
}
